---
const phi = (1 + Math.sqrt(5)) / 2;

const buildSpiralPath = (steps = 240) => {
  const centerX = 136;
  const centerY = 170;
  const startTheta = 0.35;
  const endTheta = Math.PI * 4.35;
  const scale = 2.65;

  const points = Array.from({ length: steps }, (_, index) => {
    const progress = index / (steps - 1);
    const theta = startTheta + (endTheta - startTheta) * progress;
    const radius = scale * Math.pow(phi, theta / (Math.PI / 2));
    const x = centerX + Math.cos(theta) * radius;
    const y = centerY + Math.sin(theta) * radius;
    return `${index === 0 ? 'M' : 'L'} ${x.toFixed(2)} ${y.toFixed(2)}`;
  });

  return points.join(' ');
};

const buildSpiralGuides = () => {
  const radii = [18, 29, 47, 76, 123];

  return radii.map((radius, index) => ({
    radius,
    x: 136 + index * 8,
    y: 170 - index * 7,
  }));
};

type Point = [number, number];

const midpoint = (a: Point, b: Point): Point => [(a[0] + b[0]) / 2, (a[1] + b[1]) / 2];

const buildSierpinski = (a: Point, b: Point, c: Point, depth: number): string[] => {
  if (depth === 0) {
    return [`${a[0]},${a[1]} ${b[0]},${b[1]} ${c[0]},${c[1]}`];
  }

  const ab = midpoint(a, b);
  const bc = midpoint(b, c);
  const ca = midpoint(c, a);

  return [
    ...buildSierpinski(a, ab, ca, depth - 1),
    ...buildSierpinski(ab, b, bc, depth - 1),
    ...buildSierpinski(ca, bc, c, depth - 1),
  ];
};

const spiralPath = buildSpiralPath();
const spiralGuides = buildSpiralGuides();
const sierpinskiPolygons = buildSierpinski([180, 22], [16, 306], [344, 306], 4);

const morphShapes = [
  {
    className: 'fractal-morph-shape-circle',
    element: 'circle',
    attrs: { cx: '180', cy: '180', r: '116' },
  },
  {
    className: 'fractal-morph-shape-square',
    element: 'rect',
    attrs: { x: '72', y: '72', width: '216', height: '216', rx: '28' },
  },
  {
    className: 'fractal-morph-shape-triangle',
    element: 'polygon',
    attrs: { points: '180,52 64,290 296,290' },
  },
  {
    className: 'fractal-morph-shape-hexagon',
    element: 'polygon',
    attrs: { points: '180,48 280,108 280,252 180,312 80,252 80,108' },
  },
];
---

<div class="fractal-layer" aria-hidden="true">
  <canvas data-fractal-role="mandelbrot" class="fractal-canvas fractal-canvas-mandelbrot"></canvas>

  <svg class="fractal-overlay fractal-overlay-fibonacci" viewBox="0 0 320 340" aria-hidden="true">
    <g class="fractal-motion fractal-motion-fibonacci">
      {spiralGuides.map((guide, index) => (
        <circle
          class={`fractal-guide fractal-guide-${index + 1}`}
          cx={guide.x}
          cy={guide.y}
          r={guide.radius}
        />
      ))}
      <path class="fractal-spiral fractal-spiral-halo" d={spiralPath}></path>
      <path class="fractal-spiral fractal-spiral-core" d={spiralPath}></path>
    </g>
  </svg>

  <svg class="fractal-overlay fractal-overlay-sierpinski" viewBox="0 0 360 320" aria-hidden="true">
    <g class="fractal-motion fractal-motion-sierpinski">
      <polygon class="fractal-triangle-shell" points="180,22 16,306 344,306" />
      {sierpinskiPolygons.map((points, index) => (
        <polygon
          class={`fractal-triangle fractal-triangle-${(index % 6) + 1}`}
          points={points}
        />
      ))}
    </g>
  </svg>

  <svg class="fractal-overlay fractal-overlay-morph" viewBox="0 0 360 360" aria-hidden="true">
    <g class="fractal-motion fractal-motion-morph">
      {morphShapes.map((shape) => (
        shape.element === 'circle' ? (
          <circle class={`fractal-morph-shape ${shape.className}`} {...shape.attrs}></circle>
        ) : shape.element === 'rect' ? (
          <rect class={`fractal-morph-shape ${shape.className}`} {...shape.attrs}></rect>
        ) : (
          <polygon class={`fractal-morph-shape ${shape.className}`} {...shape.attrs}></polygon>
        )
      ))}
    </g>
  </svg>
</div>

<script is:inline>
  (() => {
    const canvas = document.querySelector('[data-fractal-role="mandelbrot"]');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const context = canvas.getContext('2d', { alpha: true });
    if (!context) return;

    let width = 0;
    let height = 0;
    let rafId = 0;
    let lastFrame = 0;
    const maxIterations = 56;

    const palette = [
      [13, 53, 102],
      [33, 17, 102],
      [72, 92, 224],
      [101, 72, 224],
      [152, 74, 225],
      [72, 188, 224],
      [147, 157, 224],
    ];

    const mix = (a, b, t) => a + (b - a) * t;

    const sampleColor = (value) => {
      const scaled = value * (palette.length - 1);
      const index = Math.floor(scaled);
      const nextIndex = Math.min(index + 1, palette.length - 1);
      const t = scaled - index;
      const start = palette[index];
      const end = palette[nextIndex];

      return [
        Math.round(mix(start[0], end[0], t)),
        Math.round(mix(start[1], end[1], t)),
        Math.round(mix(start[2], end[2], t)),
      ];
    };

    const resize = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
      const nextWidth = Math.max(420, Math.floor(window.innerWidth * 0.72));
      const nextHeight = Math.max(320, Math.floor(window.innerHeight * 0.72));

      width = nextWidth;
      height = nextHeight;
      canvas.width = Math.floor(width * dpr);
      canvas.height = Math.floor(height * dpr);
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      context.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const render = (time = 0) => {
      if (time - lastFrame < 90) {
        rafId = requestAnimationFrame(render);
        return;
      }

      lastFrame = time;
      const image = context.createImageData(width, height);
      const data = image.data;
      const tick = time * 0.00012;
      const zoom = 0.98 + Math.sin(tick * 1.2) * 0.04;
      const centerX = -0.745 + Math.cos(tick * 0.8) * 0.014;
      const centerY = 0.12 + Math.sin(tick * 1.05) * 0.012;
      const scale = 2.45 / Math.min(width, height) / zoom;

      for (let py = 0; py < height; py += 1) {
        for (let px = 0; px < width; px += 1) {
          const x0 = centerX + (px - width * 0.5) * scale;
          const y0 = centerY + (py - height * 0.5) * scale;
          let x = 0;
          let y = 0;
          let iteration = 0;

          while (x * x + y * y <= 4 && iteration < maxIterations) {
            const xTemp = x * x - y * y + x0;
            y = 2 * x * y + y0;
            x = xTemp;
            iteration += 1;
          }

          const offset = (py * width + px) * 4;

          if (iteration === maxIterations) {
            data[offset] = 4;
            data[offset + 1] = 10;
            data[offset + 2] = 34;
            data[offset + 3] = 205;
            continue;
          }

          const smooth =
            iteration + 1 - Math.log2(Math.log2(Math.max(x * x + y * y, 1.00001)));
          const normalized = Math.max(0, Math.min(1, smooth / maxIterations));
          const [r, g, b] = sampleColor(normalized);

          data[offset] = r;
          data[offset + 1] = g;
          data[offset + 2] = b;
          data[offset + 3] = Math.round(108 + normalized * 120);
        }
      }

      context.putImageData(image, 0, 0);
      rafId = requestAnimationFrame(render);
    };

    resize();
    render();

    window.addEventListener('resize', resize, { passive: true });
    window.addEventListener('pagehide', () => cancelAnimationFrame(rafId), { once: true });
  })();
</script>
