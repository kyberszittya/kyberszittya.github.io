---
type Props = {
  kicker: string;
  title: string;
  summary: string;
  kickerKey?: string;
  titleKey?: string;
  summaryKey?: string;
};

const { kicker, title, summary, kickerKey, titleKey, summaryKey } = Astro.props;
---

<section class="section-block">
  <div class="page-intro section-surface">
    <p class="section-label" data-i18n={kickerKey}>{kicker}</p>
    <h1 class="page-title" data-i18n={titleKey}>{title}</h1>
    <p class="hero-summary" data-i18n={summaryKey}>{summary}</p>
  </div>
</section>
