---
import '../styles/global.css';
import MandelbrotBackground from '../components/MandelbrotBackground.astro';
import NavMenu from '../components/NavMenu.astro';
import { navigation } from '../data/navigation';

const { title = 'My Portfolio & Lectures' } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="site-shell">
    <MandelbrotBackground />
    <div class="page-glow page-glow-left" aria-hidden="true"></div>
    <div class="page-glow page-glow-right" aria-hidden="true"></div>
    <div class="site-frame">
      <header class="topbar">
        <a href="/" class="site-mark">
          <span class="site-mark-kicker">Kyberszittya</span>
          <span class="site-mark-title">Research and Robotics</span>
        </a>
        <NavMenu items={navigation} />
      </header>
      <main>
        <slot />
      </main>
    </div>
    <div class="page-grid" aria-hidden="true"></div>
    <div class="page-noise" aria-hidden="true"></div>
  </body>
</html>
