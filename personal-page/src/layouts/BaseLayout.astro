---
import '../styles/global.css';
import { collectBannerImages } from '../lib/bannerImages';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import FractalBackground from '../components/FractalBackground.astro';
import NavMenu from '../components/NavMenu.astro';
import { defaultLanguage, translations } from '../data/i18n';
import { navigation } from '../data/navigation';
import { emailContacts, socialLinks } from '../data/profile';

const { title = 'My Portfolio & Lectures' } = Astro.props;
const translationsJson = JSON.stringify(translations);
const bannerImages = await collectBannerImages(Astro.url.pathname);
---
<html lang={defaultLanguage}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="site-shell">
    <div class="page-hue-shift page-hue-shift-blue" aria-hidden="true"></div>
    <div class="page-hue-shift page-hue-shift-violet" aria-hidden="true"></div>
    {bannerImages.length > 0 && (
      <div class="page-banner-layer" aria-hidden="true">
        {bannerImages.map((image, index) => (
          <div
            class={`page-banner-image${bannerImages.length <= 1 ? ' is-static' : ''}`}
            style={`--slide-index: ${index}; --page-banner-count: ${Math.max(bannerImages.length, 1)}; background-image: linear-gradient(180deg, rgba(6, 11, 32, 0.28), rgba(7, 11, 32, 0.76)), url('${image}');`}
          ></div>
        ))}
      </div>
    )}
    <FractalBackground />
    <div class="page-glow page-glow-left" aria-hidden="true"></div>
    <div class="page-glow page-glow-right" aria-hidden="true"></div>
    <div class="site-frame">
      <header class="topbar">
        <a href="/" class="site-mark">
          <span class="site-mark-kicker">Kyberszittya</span>
          <span class="site-mark-title" data-i18n="site.title">Research and Robotics</span>
        </a>
        <LanguageSwitcher />
        <NavMenu items={navigation} />
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="site-footer-copy">
          <p class="site-footer-kicker">Kyberszittya</p>
          <p class="site-footer-title">Research, education, and cognitive robotics</p>
          <p class="site-footer-text">
            Semantic systems, hypergraph-based modeling, teaching materials, and academic collaboration.
          </p>
        </div>
        <div class="site-footer-links">
          <div class="site-footer-group">
            <strong>Contact</strong>
            {emailContacts.map((item) => (
              <a class="site-footer-link" href={item.href}>{item.value}</a>
            ))}
          </div>
          <div class="site-footer-group">
            <strong>Profiles</strong>
            {socialLinks
              .filter((item) => ['GitHub', 'Google Scholar', 'ResearchGate', 'ORCID'].includes(item.label))
              .map((item) => (
                <a class="site-footer-link" href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
              ))}
          </div>
        </div>
      </footer>
    </div>
    <div class="page-grid" aria-hidden="true"></div>
    <div class="page-noise" aria-hidden="true"></div>
    <script is:inline define:vars={{ translationsJson, defaultLanguage }}>
      const translations = JSON.parse(translationsJson);
      const storageKey = 'site-language';

      const applyLanguage = (language) => {
        const dictionary = translations[language] ?? translations[defaultLanguage];
        document.documentElement.lang = language;

        document.querySelectorAll('[data-i18n]').forEach((node) => {
          const key = node.getAttribute('data-i18n');
          if (!key || !dictionary[key]) return;
          node.textContent = dictionary[key];
        });

        document.querySelectorAll('[data-lang-button]').forEach((button) => {
          const isActive = button.getAttribute('data-lang-button') === language;
          button.classList.toggle('is-active', isActive);
        });
      };

      const saved = localStorage.getItem(storageKey);
      const initialLanguage = saved && translations[saved] ? saved : defaultLanguage;
      applyLanguage(initialLanguage);

      document.querySelectorAll('[data-lang-button]').forEach((button) => {
        button.addEventListener('click', () => {
          const nextLanguage = button.getAttribute('data-lang-button') || defaultLanguage;
          localStorage.setItem(storageKey, nextLanguage);
          applyLanguage(nextLanguage);
        });
      });
    </script>
  </body>
</html>
