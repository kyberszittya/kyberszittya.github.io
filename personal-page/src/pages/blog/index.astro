---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import PageSectionRenderer from '../../components/PageSectionRenderer.astro';
import { buildBlogPageSections } from '../../data/blogManifest';
import { formatBlogDate, getPostSlug, getPublishedPosts } from '../../lib/blog';

const posts = await getPublishedPosts();
const blogSections = buildBlogPageSections(
  posts.map((post) => ({
    id: post.id,
    title: post.title,
    summary: post.summary,
    category: post.category,
    tags: post.tags,
    dateLabel: formatBlogDate(post.date),
    href: `/blog/${getPostSlug(post)}`,
    featured: post.featured,
  })),
);
---

<BaseLayout title="Blog | Kyberszittya">
  <PageIntro
    kicker="Blog"
    title="Notes, essays, and framework experiments"
    summary="A typed content stream for research notes, architecture thoughts, and longer-form writing."
    inlineKicker={true}
    stats={[
      { value: `${posts.length}`, label: 'published posts' },
      { value: `${new Set(posts.map((post) => post.category)).size}`, label: 'categories' },
      { value: `${posts.filter((post) => post.featured).length}`, label: 'featured posts' },
    ]}
  />

  {blogSections.map((section) => (
    <PageSectionRenderer section={section} />
  ))}
</BaseLayout>
