---
import PageIntro from '../components/PageIntro.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialIcon from '../components/SocialIcon.astro';
import { contact, emailContacts, scholarMetrics, socialLinks } from '../data/profile';
---

<BaseLayout title="Contact | Kyberszittya">
  <PageIntro
    kicker="Contact"
    title="Open for collaboration"
    summary="Research partnerships, teaching opportunities, and interdisciplinary conversations are all welcome here."
    kickerKey="page.contact.kicker"
    titleKey="page.contact.title"
    summaryKey="page.contact.summary"
  />

  <section class="card-grid">
    {contact.map((entry, index) => (
      <article class="info-card">
        <h2 data-i18n={['contact.research', 'contact.general'][index]}>{entry.label}</h2>
        <p data-i18n={['contact.research.value', 'contact.general.value'][index]}>{entry.value}</p>
      </article>
    ))}
  </section>

  <section class="card-grid-wide">
    <section class="info-card">
      <h2 data-i18n="contact.emails">Email addresses</h2>
      <div class="stack-list compact">
        {emailContacts.map((entry, index) => (
          <article class="stack-item">
            <strong data-i18n={index === 0 ? 'profile.email.sze' : 'profile.email.obuda'}>{entry.label}</strong>
            <a class="text-link" href={entry.href}>{entry.value}</a>
          </article>
        ))}
      </div>
    </section>

    <section class="info-card">
      <h2 data-i18n="contact.metrics">Scholar metrics</h2>
      <div class="stack-list compact">
        <article class="stack-item">
          <strong data-i18n="metrics.citations">Citations</strong>
          <p data-i18n="metrics.citations.value">{scholarMetrics.citations.all} total, {scholarMetrics.citations.since2021} since 2021</p>
        </article>
        <article class="stack-item">
          <strong data-i18n="metrics.hindex">h-index</strong>
          <p data-i18n="metrics.hindex.value">{scholarMetrics.hIndex.all} total, {scholarMetrics.hIndex.since2021} since 2021</p>
        </article>
        <article class="stack-item">
          <strong data-i18n="metrics.i10index">i10-index</strong>
          <p data-i18n="metrics.i10index.value">{scholarMetrics.i10Index.all} total, {scholarMetrics.i10Index.since2021} since 2021</p>
        </article>
        <article class="stack-item">
          <strong data-i18n="contact.source">Source</strong>
          <a class="text-link" href={scholarMetrics.sourceHref} target="_blank" rel="noreferrer">
            {scholarMetrics.sourceLabel}
          </a>
        </article>
      </div>
    </section>
  </section>

  <section class="card-grid-wide">
    <section class="info-card">
      <h2 data-i18n="contact.social">Social and academic profiles</h2>
      <div class="stack-list compact">
        {socialLinks.map((item) => (
          <article class="stack-item">
            <strong class="social-heading">
              <SocialIcon label={item.label} />
              <span>{item.label}</span>
            </strong>
            <p>{item.value}</p>
            <a class="text-link" href={item.href} target="_blank" rel="noreferrer">
              <span data-i18n="contact.openProfile">Open profile</span>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="info-card">
      <h2 data-i18n="contact.metricNote">Metric note</h2>
      <div class="stack-list compact">
        <article class="stack-item">
          <strong data-i18n="contact.verification">Verification</strong>
          <span data-i18n="contact.metricNote.value">{scholarMetrics.note}</span>
        </article>
      </div>
    </section>
  </section>
</BaseLayout>
