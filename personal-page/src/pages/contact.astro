---
import PageIntro from '../components/PageIntro.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import InfoCard from '../components/InfoCard.astro';
import SocialIcon from '../components/SocialIcon.astro';
import StackList from '../components/StackList.astro';
import { contact, emailContacts, scholarMetrics, socialLinks } from '../data/profile';
---

<BaseLayout title="Contact | Kyberszittya">
  <PageIntro
    kicker="Contact"
    title="Open for collaboration"
    summary="Research partnerships, teaching opportunities, and interdisciplinary conversations are all welcome here."
    kickerKey="page.contact.kicker"
    titleKey="page.contact.title"
    summaryKey="page.contact.summary"
    inlineKicker={true}
    stats={[
      { value: `${emailContacts.length}`, label: 'direct emails' },
      { value: `${socialLinks.length}`, label: 'profiles' },
      { value: `${scholarMetrics.citations.all}`, label: 'citations tracked' },
    ]}
  />

  <section class="card-grid">
    {contact.map((entry, index) => (
      <InfoCard>
        <h2 data-i18n={['contact.research', 'contact.general'][index]}>{entry.label}</h2>
        <p data-i18n={['contact.research.value', 'contact.general.value'][index]}>{entry.value}</p>
      </InfoCard>
    ))}
  </section>

  <section class="card-grid-wide">
    <InfoCard as="section">
      <h2 data-i18n="contact.emails">Email addresses</h2>
      <StackList
        items={emailContacts.map((entry, index) => ({
          title: entry.label,
          titleKey: index === 0 ? 'profile.email.sze' : 'profile.email.obuda',
          href: entry.href,
          hrefLabel: entry.value,
        }))}
      />
    </InfoCard>

    <InfoCard as="section">
      <h2 data-i18n="contact.metrics">Scholar metrics</h2>
      <StackList
        items={[
          {
            title: 'Citations',
            titleKey: 'metrics.citations',
            text: `${scholarMetrics.citations.all} total, ${scholarMetrics.citations.since2021} since 2021`,
            textKey: 'metrics.citations.value',
          },
          {
            title: 'h-index',
            titleKey: 'metrics.hindex',
            text: `${scholarMetrics.hIndex.all} total, ${scholarMetrics.hIndex.since2021} since 2021`,
            textKey: 'metrics.hindex.value',
          },
          {
            title: 'i10-index',
            titleKey: 'metrics.i10index',
            text: `${scholarMetrics.i10Index.all} total, ${scholarMetrics.i10Index.since2021} since 2021`,
            textKey: 'metrics.i10index.value',
          },
          {
            title: 'Source',
            titleKey: 'contact.source',
            href: scholarMetrics.sourceHref,
            hrefLabel: scholarMetrics.sourceLabel,
            hrefTarget: '_blank',
            hrefRel: 'noreferrer',
          },
        ]}
      />
    </InfoCard>
  </section>

  <section class="card-grid-wide">
    <InfoCard as="section">
      <h2 data-i18n="contact.social">Social and academic profiles</h2>
      <div class="stack-list compact">
        {socialLinks.map((item) => (
          <article class="stack-item">
            <strong class="social-heading">
              <SocialIcon label={item.label} />
              <span>{item.label}</span>
            </strong>
            <p>{item.value}</p>
            <a class="text-link" href={item.href} target="_blank" rel="noreferrer">
              <span data-i18n="contact.openProfile">Open profile</span>
            </a>
          </article>
        ))}
      </div>
    </InfoCard>

    <InfoCard as="section">
      <h2 data-i18n="contact.metricNote">Metric note</h2>
      <StackList
        items={[
          {
            title: 'Verification',
            titleKey: 'contact.verification',
            lines: [scholarMetrics.note],
            lineKeys: ['contact.metricNote.value'],
          },
        ]}
      />
    </InfoCard>
  </section>
</BaseLayout>
