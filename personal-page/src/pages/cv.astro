---
import { render } from 'astro:content';
import InfoCard from '../components/InfoCard.astro';
import PageSectionNav from '../components/PageSectionNav.astro';
import PageIntro from '../components/PageIntro.astro';
import StackList from '../components/StackList.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { dissertation, education, languages, scholarProfile, skills } from '../data/profile';
import { getExperienceRecords } from '../lib/contentQueries';
import { getPublications } from '../lib/publications';

const publications = getPublications().slice(0, 6);
const experienceEntries = await getExperienceRecords();

const degreeItems = education.degrees.map((degree) => ({
  title: degree.title,
  text: degree.track,
  lines: degree.details,
}));

const dissertationItems = [
  {
    title: dissertation.title,
    text: dissertation.degree,
    lines: [dissertation.institution, dissertation.evaluation],
  },
];
---

<BaseLayout title="CV | Kyberszittya">
  <PageIntro
    kicker="CV"
    title="Academic and professional profile"
    summary="An overview of academic training, current affiliations, selected publications, and technical capabilities."
    kickerKey="page.cv.kicker"
    titleKey="page.cv.title"
    summaryKey="page.cv.summary"
    inlineKicker={true}
    stats={[
      { value: `${education.degrees.length}`, label: 'degrees' },
      { value: `${experienceEntries.length}`, label: 'affiliations' },
      { value: `${publications.length}`, label: 'selected publications' },
      { value: `${skills.length}`, label: 'technical domains' },
    ]}
  />

  <section class="page-multi-layout">
    <PageSectionNav
      title="CV sections"
      ariaLabel="CV section navigation"
      entries={[
        { href: '#cv-academic-background', label: 'Academic background' },
        { href: '#cv-dissertation', label: 'Dissertation' },
        { href: '#cv-professional-affiliations', label: 'Professional affiliations' },
        { href: '#cv-selected-publications', label: 'Selected publications' },
        { href: '#cv-technical-expertise', label: 'Technical expertise' },
      ]}
    />

    <div class="page-multi-content">
      <section class="card-grid-wide">
        <InfoCard as="section" id="cv-academic-background">
          <h2 data-i18n="page.cv.academicBackground">Academic background</h2>
          <StackList items={degreeItems} className="" />
        </InfoCard>

        <InfoCard as="section" id="cv-dissertation">
          <h2>Dissertation</h2>
          <StackList items={dissertationItems} />
          <p>{dissertation.summary}</p>
          <p>
            <a class="text-link" href="/dissertation">Open dissertation page</a>
          </p>
        </InfoCard>
      </section>

      <section class="card-grid-wide">
        <InfoCard as="section" id="cv-professional-affiliations">
          <h2 data-i18n="page.cv.professionalAffiliations">Professional affiliations</h2>
          <div class="stack-list compact">
            {await Promise.all(
              experienceEntries.map(async (role) => {
                const { Content } = await render(role.entry);
                return (
                  <article class="stack-item">
                    <strong>{role.title}</strong>
                    <p>{role.organization}</p>
                    <span>{role.period}</span>
                    <div class="cv-entry-copy">
                      <Content />
                    </div>
                  </article>
                );
              }),
            )}
          </div>
        </InfoCard>
      </section>

      <section class="card-grid-wide">
        <InfoCard as="section" id="cv-selected-publications">
          <h2 data-i18n="page.cv.selectedPublications">Selected publications</h2>
          <ul class="feature-list feature-list-light">
            {publications.map((item) => (
              <li>{item.title} {item.year ? `(${item.year})` : ''}</li>
            ))}
          </ul>
          <p>
            <a class="text-link" href="/publications" data-i18n="page.cv.fullArchive">Open full publication archive</a>
          </p>
          <p>
            <a class="text-link" href={scholarProfile.href} target="_blank" rel="noreferrer" data-i18n="page.cv.scholarProfile">Open Google Scholar profile</a>
          </p>
        </InfoCard>

        <InfoCard as="section" id="cv-technical-expertise">
          <h2 data-i18n="page.cv.technicalExpertise">Technical expertise</h2>
          <div class="chip-row">
            {skills.map((skill) => (
              <span class="chip chip-blue">{skill}</span>
            ))}
          </div>
          <h3 class="section-subtitle" data-i18n="page.cv.languages">Languages</h3>
          <div class="chip-row">
            {languages.map((language) => (
              <span class="chip">{language}</span>
            ))}
          </div>
        </InfoCard>
      </section>
    </div>
  </section>
</BaseLayout>
