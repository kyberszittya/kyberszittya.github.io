---
import InfoCard from '../components/InfoCard.astro';
import PageIntro from '../components/PageIntro.astro';
import StackList from '../components/StackList.astro';
import FeatureListCard from '../components/FeatureListCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { dissertation } from '../data/profile';

const dissertationOverviewItems = [
  {
    title: dissertation.degree,
    lines: [dissertation.institution, dissertation.evaluation],
    href: dissertation.pdfHref,
    hrefLabel: 'Open dissertation PDF',
    hrefTarget: '_blank',
    hrefRel: 'noreferrer',
  },
];
---

<BaseLayout title="Dissertation | Kyberszittya">
  <PageIntro
    kicker="Dissertation"
    title={dissertation.title}
    summary={dissertation.summary}
    inlineKicker={true}
    stats={[
      { value: dissertation.degree, label: 'document type' },
      { value: dissertation.evaluation, label: 'evaluation' },
      { value: `${dissertation.highlights.length}`, label: 'core highlights' },
    ]}
  />

  <section class="card-grid-wide">
    <InfoCard as="section" title="Overview">
      <StackList items={dissertationOverviewItems} />
      <p>{dissertation.summary}</p>
    </InfoCard>

    <FeatureListCard title="Core highlights" items={dissertation.highlights} />
  </section>
</BaseLayout>
