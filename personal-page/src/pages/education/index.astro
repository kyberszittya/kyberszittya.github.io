---
import { getCollection } from 'astro:content';
import InfoCard from '../../components/InfoCard.astro';
import PageIntro from '../../components/PageIntro.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageSectionNav from '../../components/PageSectionNav.astro';
import StackList from '../../components/StackList.astro';
import SubjectSummaryCard from '../../components/SubjectSummaryCard.astro';
import { education } from '../../data/profile';

const subjectsCollection = await getCollection('subjects');

const subjects = Array.from(
  subjectsCollection
    .reduce((map, subjectEntry) => {
      const current = map.get(subjectEntry.data.subject);
      const semesterLabels = subjectEntry.data.semesters ?? [];
      const languageLabels = subjectEntry.data.teachingLanguages ?? education.teachingProfile.languages;
      const hostUniversities = [subjectEntry.data.hostUniversity];
      const hostDepartments = [subjectEntry.data.hostDepartment];
      const degreePrograms = [subjectEntry.data.degreeProgram];

      if (!current) {
        map.set(subjectEntry.data.subject, {
          title: subjectEntry.data.subject,
          heading: subjectEntry.data.title,
          description:
            subjectEntry.data.subjectSummary ??
            `Subject materials and teaching notes for ${subjectEntry.data.subject}.`,
          semesters: semesterLabels,
          teachingLanguages: languageLabels,
          hostUniversities,
          hostDepartments,
          degreePrograms,
          neptunCode: subjectEntry.data.neptunCode,
          mascot: subjectEntry.data.mascot,
          href: `/subjects/${subjectEntry.id}`,
        });
        return map;
      }

      const mergedSemesters = Array.from(new Set([...current.semesters, ...semesterLabels]));
      const mergedLanguages = Array.from(new Set([...current.teachingLanguages, ...languageLabels]));
      const mergedHostUniversities = Array.from(new Set([...current.hostUniversities, ...hostUniversities]));
      const mergedHostDepartments = Array.from(new Set([...current.hostDepartments, ...hostDepartments]));
      const mergedDegreePrograms = Array.from(new Set([...current.degreePrograms, ...degreePrograms]));

      map.set(subjectEntry.data.subject, {
        ...current,
        description: subjectEntry.data.subjectSummary ?? current.description,
        semesters: mergedSemesters,
        teachingLanguages: mergedLanguages,
        hostUniversities: mergedHostUniversities,
        hostDepartments: mergedHostDepartments,
        degreePrograms: mergedDegreePrograms,
        neptunCode: current.neptunCode ?? subjectEntry.data.neptunCode,
        mascot: current.mascot ?? subjectEntry.data.mascot,
      });

      return map;
    }, new Map<string, {
      title: string;
      heading: string;
      description: string;
      semesters: string[];
      teachingLanguages: string[];
      hostUniversities: string[];
      hostDepartments: string[];
      degreePrograms: string[];
      neptunCode?: string;
      mascot?: { name: string; shortLabel?: string; description?: string; accent?: string; emoji?: string };
      href: string;
    }>())
    .values(),
).sort((a, b) => a.title.localeCompare(b.title));

const degreeItems = education.degrees.map((degree) => ({
  title: degree.title,
  text: degree.track,
  lines: degree.details,
}));

const teachingItems = [
  {
    title: education.teachingProfile.title,
    text: education.teachingProfile.period,
    lines: [education.teachingProfile.description],
  },
];
---

<BaseLayout title="Education | Kyberszittya">
  <PageIntro
    kicker="Education"
    title="Teaching, subjects, and supervision"
    summary="An overview of academic background, subject materials, and supervised student work."
    kickerKey="page.education.kicker"
    titleKey="page.education.title"
    summaryKey="page.education.summary"
    inlineKicker={true}
    stats={[
      { value: `${education.degrees.length}`, label: 'degrees represented' },
      { value: `${subjects.length}`, label: 'subjects' },
      { value: `${education.teachingProfile.languages.length}`, label: 'teaching languages' },
    ]}
  />

  <section class="page-multi-layout">
    <PageSectionNav
      title="Education sections"
      ariaLabel="Education section navigation"
      entries={[
        { href: '#education-academic-background', label: 'Academic background' },
        { href: '#education-teaching-experience', label: 'Teaching experience' },
        { href: '#education-subjects', label: 'Subjects' },
        { href: '#education-student-supervision', label: 'Student supervision' },
      ]}
    />

    <div class="page-multi-content">
      <section class="card-grid-wide">
        <InfoCard as="section" id="education-academic-background">
          <h2 data-i18n="page.cv.academicBackground">Academic background</h2>
          <StackList items={degreeItems} className="" />
        </InfoCard>

        <InfoCard as="section" id="education-teaching-experience">
          <h2>Teaching experience</h2>
          <StackList items={teachingItems} className="" />
          <h3 class="section-subtitle">Teaching languages</h3>
          <div class="chip-row">
            {education.teachingProfile.languages.map((language) => (
              <span class="chip chip-blue">{language}</span>
            ))}
          </div>
        </InfoCard>
      </section>

      <section class="card-grid-wide">
        <InfoCard as="section" id="education-subjects">
          <h2>Subjects</h2>
          <div class="stack-list">
            {subjects.map((subject) => (
              <SubjectSummaryCard subject={subject} />
            ))}
          </div>
        </InfoCard>

        <InfoCard as="section" id="education-student-supervision">
          <h2 data-i18n="page.education.finishedStudents">Student supervision</h2>
          <p data-i18n="page.education.finishedStudents.summary">This area brings together active and graduated student supervision, and can grow into a fuller archive as more project details are added.</p>
          <p style="margin-top: 1rem;">
            <a class="text-link" href="/education/tdk" data-i18n="page.education.openTdk">Open TDK page</a>
          </p>
          <p style="margin-top: 1rem;">
            <a class="text-link" href="/education/thesis-faq" data-i18n="page.education.openThesisFaq">Open thesis FAQ</a>
          </p>
          <a class="text-link" href="/education/students" data-i18n="page.education.openFinishedStudents">Open student supervision</a>
        </InfoCard>
      </section>
    </div>
  </section>
</BaseLayout>
