---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageIntro from '../../../components/PageIntro.astro';

export async function getStaticPaths() {
  const students = await getCollection('students');
  return students.map((student) => ({
    params: { id: student.id },
    props: { student },
  }));
}

const { student } = Astro.props;
const { Content } = await render(student);
const [degree = 'Student', yearFolder = ''] = student.id.split('/');
const degreeLabel = degree.toUpperCase();
---

<BaseLayout title={`${student.data.name} | Student`}>
  <PageIntro
    kicker="Education"
    title={student.data.name}
    summary={student.data.researchTopic}
    kickerKey="page.students.kicker"
  />

  <section class="card-grid-wide">
    <section class:list={['info-card', !student.data.active && 'graduated-card']}>
      <h2>Student overview</h2>
      <div class="stack-list compact">
        {!student.data.active && (
          <article class="stack-item graduated-card">
            <strong><span class="graduation-glyph" aria-hidden="true"></span><span data-i18n="student.status.graduated">Graduated</span></strong>
          </article>
        )}
        {student.data.active && (
          <article class="stack-item">
            <strong><span class="ongoing-glyph" aria-hidden="true"></span><span data-i18n="student.status.ongoing">Ongoing</span></strong>
          </article>
        )}
        <article class="stack-item">
          <strong>Degree</strong>
          <span>{degreeLabel}</span>
        </article>
        {student.data.program && (
          <article class="stack-item">
            <strong>Program</strong>
            <span>{student.data.program}</span>
          </article>
        )}
        {student.data.startSemester && (
          <article class="stack-item">
            <strong>Start semester</strong>
            <span>{student.data.startSemester}</span>
          </article>
        )}
        {student.data.endSemester && (
          <article class="stack-item">
            <strong>End semester</strong>
            <span>{student.data.endSemester}</span>
          </article>
        )}
        {student.data.graduationYear && (
          <article class="stack-item">
            <strong>Graduation year</strong>
            <span>{student.data.graduationYear}</span>
          </article>
        )}
        {yearFolder && (
          <article class="stack-item">
            <strong>Folder year</strong>
            <span>{yearFolder}</span>
          </article>
        )}
      </div>
    </section>

    <section class="info-card">
      <h2>Topic summary</h2>
      <p>{student.data.researchTopic}</p>
      {student.data.note && <p><strong>Note:</strong> {student.data.note}</p>}
      <a class="text-link" href="/education/students">Back to student supervision</a>
    </section>
  </section>

  <section class="info-card">
    <h2>Notes</h2>
    <div class="prose prose-invert max-w-none lecture-prose">
      <Content />
    </div>
  </section>
</BaseLayout>
