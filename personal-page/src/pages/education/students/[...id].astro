---
import { render } from 'astro:content';
import InfoCard from '../../../components/InfoCard.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageIntro from '../../../components/PageIntro.astro';
import PageSectionNav from '../../../components/PageSectionNav.astro';
import StackList from '../../../components/StackList.astro';
import { getStudentWorkRecords } from '../../../lib/contentQueries';

export async function getStaticPaths() {
  const students = await getStudentWorkRecords();
  return students.map((student) => ({
    params: { id: student.id },
    props: { student },
  }));
}

const { student } = Astro.props;
const { Content } = await render(student.entry);
const overviewItems = [
  student.active
    ? {
        title: 'Ongoing',
        titleKey: 'student.status.ongoing',
      }
    : {
        title: 'Graduated',
        titleKey: 'student.status.graduated',
        className: 'graduated-card',
      },
  {
    title: 'Degree',
    lines: [student.degreeLabel],
  },
  student.program
    ? {
        title: 'Program',
        lines: [student.program],
      }
    : null,
  student.startSemester
    ? {
        title: 'Start semester',
        lines: [student.startSemester],
      }
    : null,
  student.endSemester
    ? {
        title: 'End semester',
        lines: [student.endSemester],
      }
    : null,
  student.graduationYear
    ? {
        title: 'Graduation year',
        lines: [String(student.graduationYear)],
      }
    : null,
  student.folderYear
    ? {
        title: 'Folder year',
        lines: [student.folderYear],
      }
    : null,
].filter(Boolean);
---

<BaseLayout title={`${student.name} | Student`}>
  <PageIntro
    kicker="Education"
    title={student.name}
    summary={student.researchTopic}
    kickerKey="page.students.kicker"
  />

  <section class="page-multi-layout">
    <PageSectionNav
      title="Student page"
      ariaLabel="Student page section navigation"
      entries={[
        { href: '#student-overview', label: 'Student overview' },
        { href: '#student-topic-summary', label: 'Topic summary' },
        { href: '#student-notes', label: 'Notes' },
      ]}
    />

    <div class="page-multi-content">
      <section class="card-grid-wide">
        <InfoCard as="section" className={!student.active ? 'graduated-card' : ''} id="student-overview">
          <h2>Student overview</h2>
          <StackList items={overviewItems} />
        </InfoCard>

        <InfoCard as="section" id="student-topic-summary">
          <h2>Topic summary</h2>
          <p>{student.researchTopic}</p>
          {student.note && <p><strong>Note:</strong> {student.note}</p>}
          <a class="text-link" href="/education/students">Back to student supervision</a>
        </InfoCard>
      </section>

      <InfoCard as="section" id="student-notes">
        <h2>Notes</h2>
        <div class="prose prose-invert max-w-none lecture-prose">
          <Content />
        </div>
      </InfoCard>
    </div>
  </section>
</BaseLayout>
