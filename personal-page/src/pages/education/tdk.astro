---
import { getCollection } from 'astro:content';
import FeatureListCard from '../../components/FeatureListCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import PageSectionNav from '../../components/PageSectionNav.astro';
import TdkEntryCard from '../../components/TdkEntryCard.astro';
import { tdkGuideSections } from '../../data/educationContent';

const tdkEntries = await getCollection('tdk');

tdkEntries.sort((a, b) => {
  const yearDiff = b.data.year - a.data.year;
  if (yearDiff !== 0) return yearDiff;
  return a.data.studentName.localeCompare(b.data.studentName);
});
---

<BaseLayout title="TDK | Kyberszittya">
  <PageIntro
    kicker="Education"
    title="TDK and student research"
    summary="A dedicated page for Scientific Students’ Associations work, student research directions, and preparation for TDK submissions."
    kickerKey="page.tdk.kicker"
    titleKey="page.tdk.title"
    summaryKey="page.tdk.summary"
  />

  <section class="page-multi-layout">
    <PageSectionNav
      title="TDK sections"
      ariaLabel="TDK section navigation"
      entries={[
        ...tdkGuideSections.foundations.map((section) => ({
          href: `#${section.id}`,
          label: section.title,
        })),
        { href: '#tdk-students', label: 'Recent students' },
        ...tdkGuideSections.practice.map((section) => ({
          href: `#${section.id}`,
          label: section.title,
        })),
      ]}
    />

    <div class="page-multi-content">
      <section class="card-grid-wide">
        {tdkGuideSections.foundations.map((section) => (
          <FeatureListCard id={section.id} title={section.title} items={[...section.items]} />
        ))}
      </section>

      <section class="card-grid-wide">
        <section class="info-card" id="tdk-students">
          <h2>Recent TDK-related students</h2>
          <div class="stack-list compact">
            {tdkEntries.map((entry) => (
              <TdkEntryCard
                studentName={entry.data.studentName}
                studentHref={entry.data.studentHref}
                workTitle={entry.data.workTitle}
                summary={entry.data.summary}
                placement={entry.data.placement}
                year={entry.data.year}
                sourceNote={entry.data.sourceNote}
                graduated={entry.data.graduated}
              />
            ))}
          </div>
        </section>

        <FeatureListCard
          id={tdkGuideSections.practice[0].id}
          title={tdkGuideSections.practice[0].title}
          items={[...tdkGuideSections.practice[0].items]}
        />
      </section>

      <section class="card-grid-wide">
        <FeatureListCard
          id={tdkGuideSections.practice[1].id}
          title={tdkGuideSections.practice[1].title}
          items={[...tdkGuideSections.practice[1].items]}
        />
      </section>
    </div>
  </section>
</BaseLayout>
