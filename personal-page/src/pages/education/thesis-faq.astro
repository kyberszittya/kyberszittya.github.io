---
import FeatureListCard from '../../components/FeatureListCard.astro';
import PageIntro from '../../components/PageIntro.astro';
import PageSectionNav from '../../components/PageSectionNav.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { thesisFaqSections } from '../../data/educationContent';
---

<BaseLayout title="Thesis FAQ | Kyberszittya">
  <PageIntro
    kicker="Education"
    title="Thesis FAQ and key guidance"
    summary="A short orientation page for thesis work, practical expectations, and the most important things to know before starting."
    kickerKey="page.thesisFaq.kicker"
    titleKey="page.thesisFaq.title"
    summaryKey="page.thesisFaq.summary"
  />

  <section class="page-multi-layout">
    <PageSectionNav
      title="Thesis FAQ"
      ariaLabel="Thesis FAQ section navigation"
      entries={thesisFaqSections.map((section) => ({
        href: `#${section.id}`,
        label: section.title,
      }))}
    />

    <div class="page-multi-content">
      <section class="card-grid-wide">
        {thesisFaqSections.slice(0, 2).map((section) => (
          <FeatureListCard
            id={section.id}
            title={section.title}
            titleKey={section.titleKey}
            items={[...section.items]}
            itemKeys={[...section.itemKeys]}
          />
        ))}
      </section>

      <section class="card-grid-wide">
        {thesisFaqSections.slice(2).map((section) => (
          <FeatureListCard
            id={section.id}
            title={section.title}
            titleKey={section.titleKey}
            items={[...section.items]}
            itemKeys={[...section.itemKeys]}
          />
        ))}
      </section>
    </div>
  </section>
</BaseLayout>
