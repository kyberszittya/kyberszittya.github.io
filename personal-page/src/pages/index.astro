---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kyberszittya | Researcher & Engineer">
  <header class="mb-10 border-b border-slate-200 pb-6">
    <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 mb-2">Kyberszittya</h1>
    <p class="text-xl text-slate-600">Researcher in Autonomous Systems & Critical Infrastructure</p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
    <section class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
      <h2 class="text-2xl font-bold mb-4 text-blue-700">Academic Background</h2>
      <ul class="space-y-4 text-slate-700">
        <li>
          <strong>MSc in Computer Science</strong> (Critical Systems) <br/>
          <span class="text-sm text-slate-500">Budapest University of Technology and Economics (BME)</span>
        </li>
        <li>
          <strong>BSc in Computer Science</strong> <br/>
          <span class="text-sm text-slate-500">Budapest University of Technology and Economics (BME)</span>
        </li>
        <li class="pt-2 border-t border-slate-100">
          <strong>Current Role:</strong> Researcher at the Vehicle Research Centre, Széchenyi István University
        </li>
      </ul>
    </section>

    <section class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
      <h2 class="text-2xl font-bold mb-4 text-blue-700">Languages & Interests</h2>
      <p class="text-slate-700 mb-4"><strong>Interests:</strong> Robotics, Cyberpunk, Visual Arts, Japanese Culture</p>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full font-medium">Hungarian (Native)</span>
        <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full font-medium">English (B2)</span>
        <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full font-medium">German (B2)</span>
        <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full font-medium">Japanese (Basic)</span>
        <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full font-medium">Croatian (Basic)</span>
      </div>
    </section>
  </div>

  <section class="mb-10">
    <h2 class="text-2xl font-bold mb-4 text-blue-700">Technical Expertise</h2>
    <div class="flex flex-wrap gap-2">
      {['ROS & ROS2', 'Gazebo & LGSVL', 'DDS (Connext/FastRTPS)', 'FreeRTOS & Arduino', 'Neural Networks & RL', 'Verification & Validation', 'Model-Based Systems Engineering', 'UML & SysML'].map((skill) => (
        <span class="px-3 py-1 bg-blue-100 text-blue-800 text-sm rounded-md font-medium">{skill}</span>
      ))}
    </div>
  </section>

  <section class="bg-slate-900 text-slate-50 p-8 rounded-xl shadow-md">
    <h2 class="text-2xl font-bold mb-4 text-blue-400">Current Research Challenges</h2>
    <ul class="list-disc list-inside space-y-2 text-slate-300">
      <li>Autonomous vehicle trajectory following</li>
      <li>Precise geolocation-based localization</li>
      <li>Decision processes of autonomous systems</li>
      <li>Model-based environment generation</li>
      <li>Specification-based monitoring of test environments</li>
      <li>Simulator-based V&V of autonomous systems</li>
    </ul>
  </section>
</BaseLayout>