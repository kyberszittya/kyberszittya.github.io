---
import BaseLayout from '../layouts/BaseLayout.astro';
import { hero, overviewLinks, researchAreas } from '../data/profile';
---

<BaseLayout title="Kyberszittya | Researcher & Engineer">
  <section class="hero-panel">
    <div class="hero-copy">
      <p class="hero-kicker">{hero.handle}</p>
      <h1 class="hero-title">{hero.name}</h1>
      <p class="hero-role">{hero.role}</p>
      <p class="hero-tagline">{hero.tagline}</p>
      <p class="hero-summary">{hero.summary}</p>

      <div class="hero-actions">
        <a href="/research" class="button-primary">Explore research</a>
        <a href="/contact" class="button-secondary">Get in touch</a>
      </div>
    </div>

    <div class="hero-side">
      <div class="hero-orbit hero-orbit-one"></div>
      <div class="hero-orbit hero-orbit-two"></div>
      <div class="hero-card-stack">
        {hero.stats.map((stat) => (
          <div class="stat-card">
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-block">
    <div class="section-surface">
      <div class="section-heading">
        <p class="section-label">Overview</p>
        <h2>Research, education, and creative directions</h2>
      </div>
      <div class="copy-grid">
        {hero.intro.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <section class="card-grid">
    {overviewLinks.map((item) => (
      <article class="info-card">
        <h3>{item.label}</h3>
        <p>{item.description}</p>
        <a class="text-link" href={item.href}>Open {item.label}</a>
      </article>
    ))}
  </section>

  <section class="section-block">
    <div class="section-heading section-heading-on-dark">
      <p class="section-label">Research highlights</p>
      <h2>Current topic pages</h2>
    </div>
    <div class="card-grid">
      {researchAreas.map((area) => (
        <article class="info-card">
          <h3>{area.title}</h3>
          <p>{area.description}</p>
          <a class="text-link" href={`/research/${area.slug}`}>Open topic page</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
