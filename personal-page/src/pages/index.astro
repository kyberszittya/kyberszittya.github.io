---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroMathOrnaments from '../components/HeroMathOrnaments.astro';
import { dissertation, emailContacts, hero, overviewLinks, researchAreas, scholarMetrics, socialLinks } from '../data/profile';

const students = await getCollection('students');
const graduatedStudentCount = students.filter((student) => !student.data.active).length;
const completedStudentCount = students.filter((student) => !student.data.active).length;
const graduatedStudentPercentage = completedStudentCount > 0
  ? Math.round((graduatedStudentCount / completedStudentCount) * 100)
  : 0;
const heroSocialLinks = socialLinks.filter((item) =>
  ['GitHub', 'Twitter/X', 'Google Scholar', 'ResearchGate', 'ORCID'].includes(item.label),
);

const heroStats = [
  { value: '211', label: 'citations', key: 'profile.stat.citations' },
  { value: '7', label: 'h-index', key: 'profile.stat.hindex' },
  { value: `${graduatedStudentCount} · ${graduatedStudentPercentage}%`, label: 'graduated students', key: 'profile.stat.graduatedStudents' },
  { value: '2', label: 'active affiliations', key: 'profile.stat.affiliations' },
  { value: 'AI + Robotics', label: 'core domain', key: 'profile.stat.domain' },
];
---

<BaseLayout title="Kyberszittya | Researcher & Engineer">
  <section class="hero-panel hero-panel-fibonacci">
    <div class="hero-copy">
      <p class="hero-kicker">{hero.handle}</p>
      <h1 class="hero-title">{hero.name}</h1>
      <p class="hero-role">{hero.role}</p>
      <p class="hero-tagline">{hero.tagline}</p>
      <p class="hero-summary" data-i18n="home.hero.summary">{hero.summary}</p>

      <div class="hero-actions">
        <a href="/research" class="button-primary" data-i18n="home.hero.ctaResearch">Explore research</a>
        <a href="/contact" class="button-secondary" data-i18n="home.hero.ctaContact">Get in touch</a>
      </div>

      <div class="hero-social-strip">
        {heroSocialLinks.map((item) => (
          <a class="hero-social-link" href={item.href} target="_blank" rel="noreferrer" aria-label={item.label}>
            {item.label === 'GitHub' && <span class="social-badge github" aria-hidden="true">GH</span>}
            {item.label === 'Twitter/X' && <span class="social-badge x" aria-hidden="true">X</span>}
            {item.label === 'ResearchGate' && <span class="social-badge researchgate" aria-hidden="true">RG</span>}
            {item.label === 'Google Scholar' && <span class="social-badge scholar" aria-hidden="true">GS</span>}
            {item.label === 'ORCID' && <span class="social-badge orcid" aria-hidden="true">ID</span>}
            <span>{item.label}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="hero-side">
      <HeroMathOrnaments />
      <div class="hero-card-stack">
        {heroStats.map((stat, index) => (
          <div class={`stat-card stat-card-${index + 1}`}>
            <strong>{stat.value}</strong>
            <span data-i18n={stat.key}>{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-block section-row section-row-cyan">
    <div class="section-surface section-surface-golden">
      <div class="section-heading">
        <p class="section-label" data-i18n="home.overview.kicker">Overview</p>
        <h2 data-i18n="home.overview.title">Research, education, and creative directions</h2>
      </div>
      <div class="copy-grid copy-grid-golden">
        {hero.intro.map((paragraph, index) => (
          <p data-i18n={`home.intro.${index}`}>{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <section class="card-grid-wide card-grid-golden card-grid-golden-wide section-row section-row-blue">
    <article class="info-card">
      <p class="section-label" data-i18n="home.contact.kicker">Main contact</p>
      <h2 data-i18n="home.contact.title">University email addresses</h2>
      <div class="stack-list compact">
        {emailContacts.map((entry, index) => (
          <article class="stack-item">
            <strong data-i18n={index === 0 ? 'profile.email.sze' : 'profile.email.obuda'}>{entry.label}</strong>
            <a class="text-link" href={entry.href}>{entry.value}</a>
          </article>
        ))}
      </div>
    </article>

    <article class="info-card">
      <p class="section-label" data-i18n="home.metrics.kicker">Scholar metrics</p>
      <h2 data-i18n="home.metrics.title">Research visibility at a glance</h2>
      <div class="stack-list compact">
        <article class="stack-item">
          <strong data-i18n="metrics.citations">Citations</strong>
          <p data-i18n="metrics.citations.value">{scholarMetrics.citations.all} total, {scholarMetrics.citations.since2021} since 2021</p>
        </article>
        <article class="stack-item">
          <strong data-i18n="metrics.hindex">h-index</strong>
          <p data-i18n="metrics.hindex.value">{scholarMetrics.hIndex.all} total, {scholarMetrics.hIndex.since2021} since 2021</p>
        </article>
        <article class="stack-item">
          <strong data-i18n="metrics.i10index">i10-index</strong>
          <p data-i18n="metrics.i10index.value">{scholarMetrics.i10Index.all} total, {scholarMetrics.i10Index.since2021} since 2021</p>
        </article>
      </div>
    </article>
  </section>

  <section class="card-grid-wide card-grid-golden card-grid-golden-wide section-row section-row-violet">
    <article class="info-card">
      <p class="section-label">Dissertation</p>
      <h2>{dissertation.title}</h2>
      <p>{dissertation.summary}</p>
      <div class="stack-list compact">
        <article class="stack-item">
          <strong>{dissertation.degree}</strong>
          <span>{dissertation.institution}</span>
          <span>{dissertation.evaluation}</span>
        </article>
      </div>
      <p>
        <a class="text-link" href="/dissertation">Open dissertation overview</a>
      </p>
    </article>

    <article class="info-card">
      <p class="section-label">Featured research</p>
      <h2>HyMeKo</h2>
      <p>
        Hypergraph-based semantic modeling for representing knowledge, behavior, and cognitive structure across robotics and intelligent systems.
      </p>
      <div class="stack-list compact">
        <article class="stack-item">
          <strong>Research link</strong>
          <a class="text-link" href="/research/hymeko">Open HyMeKo page</a>
        </article>
        <article class="stack-item">
          <strong>Dissertation link</strong>
          <a class="text-link" href="/dissertation">Open dissertation overview</a>
        </article>
      </div>
    </article>

  </section>

  <section class="floating-reach-band section-row section-row-magenta">
    <article class="info-card info-card-hero-reach info-card-hero-reach-wide">
      <div class="floating-reach-copy">
        <p class="section-label">Academic reach</p>
        <h2>Where to find my work</h2>
        <p class="floating-reach-summary">
          Profiles, code, citations, and academic presence collected in one place for quick access.
        </p>
      </div>
      <div class="chip-row chip-row-large chip-row-dock">
        {heroSocialLinks.map((item) => (
          <a class="chip chip-link chip-link-large chip-link-dock" href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
        ))}
      </div>
    </article>
  </section>

  <section class="card-grid card-grid-golden section-row section-row-indigo">
    {overviewLinks.map((item) => (
      <article class="info-card">
        <h3>{item.label}</h3>
        <p>{item.description}</p>
        <a class="text-link" href={item.href}><span data-i18n="common.open">Open</span> {item.label}</a>
      </article>
    ))}
  </section>

  <section class="section-block section-row section-row-cyan-soft">
    <div class="section-heading section-heading-on-dark">
      <p class="section-label" data-i18n="home.researchHighlights.kicker">Research highlights</p>
      <h2 data-i18n="home.researchHighlights.title">Current topic pages</h2>
    </div>
    <div class="card-grid card-grid-golden">
      {researchAreas.map((area) => (
        <article class="info-card">
          <h3>{area.title}</h3>
          <p>{area.description}</p>
          <a class="text-link" href={`/research/${area.slug}`} data-i18n="common.openTopicPage">Open topic page</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
