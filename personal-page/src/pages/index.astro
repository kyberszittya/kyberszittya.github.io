---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroMathOrnaments from '../components/HeroMathOrnaments.astro';
import InfoCard from '../components/InfoCard.astro';
import StackList from '../components/StackList.astro';
import {
  academicReachSection,
  buildHomeHeroStats,
  heroActions,
  heroSocialLabels,
  homeFeatureCards,
  homePrimaryCards,
  overviewCards,
  overviewSection,
  researchHighlightSection,
} from '../data/home';
import { hero, socialLinks } from '../data/site';
import { getStudentMetrics } from '../lib/contentQueries';

const { graduatedCount, graduatedPercentage } = await getStudentMetrics();
const heroSocialLinks = socialLinks.filter((item) => heroSocialLabels.includes(item.label));
const heroStats = buildHomeHeroStats({ graduatedStudentCount: graduatedCount, graduatedStudentPercentage: graduatedPercentage });
---

<BaseLayout title="Kyberszittya | Researcher & Engineer">
  <section class="hero-panel hero-panel-fibonacci">
    <div class="hero-copy">
      <p class="hero-kicker">{hero.handle}</p>
      <h1 class="hero-title">{hero.name}</h1>
      <p class="hero-role">{hero.role}</p>
      <p class="hero-tagline">{hero.tagline}</p>
      <p class="hero-summary" data-i18n="home.hero.summary">{hero.summary}</p>

      <div class="hero-actions">
        {heroActions.map((action) => (
          <a href={action.href} class={action.variant} data-i18n={action.key}>{action.label}</a>
        ))}
      </div>

      <div class="hero-social-strip">
        {heroSocialLinks.map((item) => (
          <a class="hero-social-link" href={item.href} target="_blank" rel="noreferrer" aria-label={item.label}>
            {item.label === 'GitHub' && <span class="social-badge github" aria-hidden="true">GH</span>}
            {item.label === 'Twitter/X' && <span class="social-badge x" aria-hidden="true">X</span>}
            {item.label === 'ResearchGate' && <span class="social-badge researchgate" aria-hidden="true">RG</span>}
            {item.label === 'Google Scholar' && <span class="social-badge scholar" aria-hidden="true">GS</span>}
            {item.label === 'ORCID' && <span class="social-badge orcid" aria-hidden="true">ID</span>}
            <span>{item.label}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="hero-side">
      <HeroMathOrnaments />
      <div class="hero-card-stack">
        {heroStats.map((stat, index) => (
          <div class={`stat-card stat-card-${index + 1}`}>
            <strong>{stat.value}</strong>
            <span data-i18n={stat.key}>{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-block section-row section-row-cyan">
    <div class="section-surface section-surface-golden">
      <div class="section-heading">
        <p class="section-label" data-i18n={overviewSection.kickerKey}>{overviewSection.kicker}</p>
        <h2 data-i18n={overviewSection.titleKey}>{overviewSection.title}</h2>
      </div>
      <div class="copy-grid copy-grid-golden">
        {hero.intro.map((paragraph, index) => (
          <p data-i18n={`home.intro.${index}`}>{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <section class="card-grid-wide card-grid-golden card-grid-golden-wide section-row section-row-blue">
    {homePrimaryCards.map((card) => (
      <InfoCard kicker={card.kicker} kickerKey={card.kickerKey} title={card.title} titleKey={card.titleKey}>
        <StackList items={card.items} />
      </InfoCard>
    ))}
  </section>

  <section class="card-grid-wide card-grid-golden card-grid-golden-wide section-row section-row-violet">
    {homeFeatureCards.map((card) => (
      <InfoCard kicker={card.kicker} title={card.title}>
        <p>{card.summary}</p>
        <StackList items={card.items} />
        {card.cta && (
          <p>
            <a class="text-link" href={card.cta.href}>{card.cta.label}</a>
          </p>
        )}
      </InfoCard>
    ))}
  </section>

  <section class="floating-reach-band section-row section-row-magenta">
    <InfoCard className="info-card-hero-reach info-card-hero-reach-wide">
      <div class="floating-reach-copy">
        <p class="section-label">{academicReachSection.kicker}</p>
        <h2>{academicReachSection.title}</h2>
        <p class="floating-reach-summary">{academicReachSection.summary}</p>
      </div>
      <div class="chip-row chip-row-large chip-row-dock">
        {academicReachSection.links.map((item) => (
          <a class="chip chip-link chip-link-large chip-link-dock" href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
        ))}
      </div>
    </InfoCard>
  </section>

  <section class="card-grid card-grid-golden section-row section-row-indigo">
    {overviewCards.map((item) => (
      <InfoCard>
        <h3>{item.title}</h3>
        <p>{item.description}</p>
        <a class="text-link" href={item.href}><span data-i18n="common.open">Open</span> {item.title}</a>
      </InfoCard>
    ))}
  </section>

  <section class="section-block section-row section-row-cyan-soft">
    <div class="section-heading section-heading-on-dark">
      <p class="section-label" data-i18n={researchHighlightSection.kickerKey}>{researchHighlightSection.kicker}</p>
      <h2 data-i18n={researchHighlightSection.titleKey}>{researchHighlightSection.title}</h2>
    </div>
    <div class="card-grid card-grid-golden">
      {researchHighlightSection.cards.map((area) => (
        <InfoCard>
          <h3>{area.title}</h3>
          <p>{area.description}</p>
          <a class="text-link" href={area.href} data-i18n={area.hrefKey}>{area.hrefLabel}</a>
        </InfoCard>
      ))}
    </div>
  </section>
</BaseLayout>
