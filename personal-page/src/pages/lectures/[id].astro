---
import { readdir } from 'node:fs/promises';
import { extname, join } from 'node:path';
import { fileURLToPath } from 'node:url';
import { getCollection, render } from 'astro:content';
import ImageGallery from '../../components/ImageGallery.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

// 1. The Build Engine: Tells Astro which pages to generate
export async function getStaticPaths() {
  const lectures = await getCollection('lectures');
  return lectures.map((lecture) => ({
    params: { id: lecture.id },
    props: { lecture },
  }));
}

// 2. The Renderer: Extracts the data for the current URL
const { lecture } = Astro.props;
const { Content } = await render(lecture);

const publicRoot = fileURLToPath(new URL('../../../public', import.meta.url));
let mascotGallery: string[] = [];

if (lecture.data.mascot?.image) {
  const publicDir = join(publicRoot, lecture.data.mascot.image.replace(/^\//, '').split('/').slice(0, -1).join('/'));

  try {
    const files = await readdir(publicDir);
    mascotGallery = files
      .filter((file) => ['.png', '.jpg', '.jpeg', '.webp'].includes(extname(file).toLowerCase()))
      .sort((a, b) => a.localeCompare(b))
      .map((file) => `${lecture.data.mascot?.image?.split('/').slice(0, -1).join('/')}/${file}`);
  } catch {
    mascotGallery = lecture.data.mascot.image ? [lecture.data.mascot.image] : [];
  }
}

const mascotGalleryItems = mascotGallery.map((image, index) => ({
  src: image,
  alt: `${lecture.data.mascot?.name ?? lecture.data.subject} gallery image ${index + 1}`,
}));
---

<BaseLayout title={lecture.data.title}>
  <article class="glass-panel glass-panel-dark lecture-article">
    <header class="lecture-header">
      <h1 class="lecture-title">{lecture.data.title}</h1>
      <div class="lecture-meta-row">
        <span><span data-i18n="page.lecture.subject">Subject:</span> <strong class="lecture-subject">{lecture.data.subject}</strong></span>
        <time class="lecture-date">{lecture.data.publishDate.toDateString()}</time>
      </div>
      {(lecture.data.neptunCode || lecture.data.semesters || lecture.data.teachingLanguages) && (
        <div class="chip-row">
          {lecture.data.neptunCode && <span class="chip chip-blue">Neptun: {lecture.data.neptunCode}</span>}
          {lecture.data.semesters?.map((semester) => (
            <span class="chip">{semester}</span>
          ))}
          {lecture.data.teachingLanguages?.map((language) => (
            <span class="chip">{language}</span>
          ))}
        </div>
      )}
      {lecture.data.mascot && (
        <section class="mascot-card" style={lecture.data.mascot.accent ? `--mascot-accent: ${lecture.data.mascot.accent};` : undefined}>
          {lecture.data.mascot.image && (
            <img
              class="mascot-image"
              src={lecture.data.mascot.image}
              alt={lecture.data.mascot.name}
              loading="lazy"
            />
          )}
          <div class="mascot-badge" aria-hidden="true">
            {lecture.data.mascot.emoji ?? lecture.data.mascot.shortLabel ?? lecture.data.mascot.name.slice(0, 2).toUpperCase()}
          </div>
          <div class="mascot-copy">
            <strong>{lecture.data.mascot.name}</strong>
            {lecture.data.mascot.description && <p>{lecture.data.mascot.description}</p>}
          </div>
        </section>
      )}
    </header>
    
    <div class="prose prose-invert max-w-none lecture-prose">
      <Content />
    </div>

    <ImageGallery title="Mascot gallery" images={mascotGalleryItems} />
  </article>
</BaseLayout>
