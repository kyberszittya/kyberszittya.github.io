---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const lectures = (await getCollection('lectures')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);
---

<BaseLayout title="Lectures | Kyberszittya">
  <section class="section-block">
    <div class="section-heading">
      <p class="section-label" data-i18n="page.lectures.kicker">Education</p>
      <h1 class="hero-title" data-i18n="page.lectures.title" style="font-size: clamp(2.4rem, 5vw, 3.8rem); color: #f8fbff;">Lectures</h1>
      <p class="hero-summary" data-i18n="page.lectures.summary">Course materials, topics, and lecture notes published through the Astro content collection.</p>
    </div>
  </section>

  <section class="card-grid">
    {lectures.map((lecture) => (
      <article class="info-card">
        <p class="section-label">{lecture.data.subject}</p>
        <h2 style="font-size: 1.5rem;">{lecture.data.title}</h2>
        <p>{lecture.data.publishDate.toDateString()}</p>
        {lecture.data.tags && (
          <div class="chip-row">
            {lecture.data.tags.map((tag) => (
              <span class="chip chip-blue">{tag}</span>
            ))}
          </div>
        )}
        <a class="text-link" href={`/lectures/${lecture.id}`} data-i18n="page.lectures.read">Read lecture</a>
      </article>
    ))}
  </section>
</BaseLayout>
