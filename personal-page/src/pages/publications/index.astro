---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import { scholarProfile } from '../../data/profile';
import { getPublications } from '../../lib/publications';

const publications = getPublications();

const grouped = publications.reduce<Record<string, typeof publications>>((acc, publication) => {
  const key = publication.year ? String(publication.year) : 'Undated';
  acc[key] ??= [];
  acc[key].push(publication);
  return acc;
}, {});

const years = Object.keys(grouped).sort((a, b) => {
  if (a === 'Undated') return 1;
  if (b === 'Undated') return -1;
  return Number(b) - Number(a);
});
---

<BaseLayout title="Publications | Kyberszittya">
  <PageIntro
    kicker="Publications"
    title="Scholar profile and publication archive"
    summary="This archive uses the Google Scholar profile as an external reference and renders publication entries directly from the local BibTeX file."
    kickerKey="page.publications.kicker"
    titleKey="page.publications.title"
    summaryKey="page.publications.summary"
  />

  <section class="card-grid-wide">
    <section class="info-card">
      <h2 data-i18n="page.publications.scholar">Google Scholar</h2>
      <p>
        <span data-i18n="page.publications.externalProfile">External profile reference:</span>
        <a class="text-link" href={scholarProfile.href} target="_blank" rel="noreferrer">{scholarProfile.label}</a>
      </p>
      <p>
        This page uses the Scholar profile as the canonical external profile link and the local <code>cite.bibtex</code>
        file for the detailed publication archive.
      </p>
    </section>

    <section class="info-card">
      <h2 data-i18n="page.publications.archiveSummary">Archive summary</h2>
      <div class="stack-list compact">
        <article class="stack-item">
          <strong>{publications.length} entries</strong>
          <p data-i18n="page.publications.entriesLoaded">Loaded from the BibTeX file in the repository root.</p>
        </article>
        <article class="stack-item">
          <strong data-i18n="page.publications.separatePages">Separate publication pages</strong>
          <p data-i18n="page.publications.separatePages.value">Each entry gets its own route for easier future expansion.</p>
        </article>
      </div>
    </section>
  </section>

  {years.map((year) => (
    <section class="section-block">
      <div class="section-heading">
        <p class="section-label" data-i18n="page.publications.year">Year</p>
        <h2>{year}</h2>
      </div>
      <div class="card-grid">
        {grouped[year].map((publication) => (
          <article class="info-card">
            <h3>
              <a class="title-link" href={publication.externalUrl} target="_blank" rel="noreferrer">
                {publication.title}
              </a>
            </h3>
            <p>{publication.authors.join(', ')}</p>
            {publication.venue && <p><strong>Venue:</strong> {publication.venue}</p>}
            <a class="text-link" href={`/publications/${publication.slug}`} data-i18n="page.publications.openPublication">Open publication</a>
          </article>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
