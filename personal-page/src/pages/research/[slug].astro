---
import { readdir } from 'node:fs/promises';
import { extname, join, relative } from 'node:path';
import { fileURLToPath } from 'node:url';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackgroundSlideshow from '../../components/BackgroundSlideshow.astro';
import CopyBlock from '../../components/CopyBlock.astro';
import ImageGallery from '../../components/ImageGallery.astro';
import PageIntro from '../../components/PageIntro.astro';
import { dissertation, researchAreas } from '../../data/profile';
import { getHymekoBibtexEntries } from '../../lib/hymekoBibtex';
import { researchDetails } from '../../data/researchDetails';

type GalleryItem = {
  src: string;
  alt: string;
  type?: 'image' | 'pdf';
};

export function getStaticPaths() {
  return researchAreas.map((area) => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;
const detail = researchDetails[area.slug as keyof typeof researchDetails];
const publicRoot = fileURLToPath(new URL('../../../public', import.meta.url));
let researchShowcaseImages: string[] = [];
let researchGalleryItems: GalleryItem[] = [];
const hymekoBibtexEntries = area.slug === 'hymeko' ? getHymekoBibtexEntries() : [];

async function collectMedia(dir: string, prefix: string): Promise<GalleryItem[]> {
  const collected: GalleryItem[] = [];
  const entries = await readdir(dir, { withFileTypes: true });

  for (const entry of entries) {
    const fullPath = join(dir, entry.name);

    if (entry.isDirectory()) {
      collected.push(...(await collectMedia(fullPath, `${prefix}/${entry.name}`)));
      continue;
    }

    const extension = extname(entry.name).toLowerCase();
    if (!['.png', '.jpg', '.jpeg', '.webp', '.pdf'].includes(extension)) {
      continue;
    }

    const label = relative(publicRoot, fullPath)
      .replace(/^research[\\/]/, '')
      .replace(/\.[^.]+$/, '')
      .replace(/[\\/]+/g, ' - ');

    collected.push({
      src: `${prefix}/${entry.name}`,
      alt: label,
      type: extension === '.pdf' ? 'pdf' : 'image',
    });
  }

  return collected.sort((a, b) => a.src.localeCompare(b.src));
}

if (area.slug === 'hymeko') {
  try {
    const backgroundItems = await collectMedia(join(publicRoot, 'research', 'backgrounds'), '/research/backgrounds');
    researchShowcaseImages.push(...backgroundItems.filter((item) => item.type !== 'pdf').map((item) => item.src));
  } catch {
    // keep empty when no background assets are present
  }

  try {
    const highlightItems = await collectMedia(join(publicRoot, 'research', 'highlights'), '/research/highlights');
    researchGalleryItems.push(...highlightItems);
    researchShowcaseImages.push(...highlightItems.filter((item) => item.type !== 'pdf').map((item) => item.src));
  } catch {
    // keep empty when no highlight assets are present
  }
}
---

<BaseLayout title={`${area.title} | Research | Kyberszittya`}>
  <PageIntro kicker="Research topic" title={area.title} summary={area.description} kickerKey="page.researchTopic.kicker" />

  {researchShowcaseImages.length > 0 && (
    <BackgroundSlideshow images={researchShowcaseImages} className="research-showcase research-showcase-hero">
      <div class="section-heading research-showcase-copy">
        <p class="section-label">Visual overview</p>
        <h2>{area.title} background and poster materials</h2>
        <p class="hero-summary">A rotating visual layer built from the visual materials currently attached to this topic.</p>
      </div>
    </BackgroundSlideshow>
  )}

  {researchGalleryItems.length > 0 && (
    <section class="section-block section-block-bleed">
      <div class="section-heading section-heading-on-dark">
        <p class="section-label">Gallery</p>
        <h2>{area.title} poster and image gallery</h2>
      </div>
      <div class="gallery-page-surface">
        <ImageGallery
          title="Poster and visual materials"
          images={researchGalleryItems}
          className="image-gallery-showcase image-gallery-page"
          maxRows={1}
        />
      </div>
    </section>
  )}

  <section class="card-grid-wide">
    <section class="info-card">
      <h2 data-i18n="page.researchTopic.overview">Overview</h2>
      <p data-i18n="page.researchTopic.overviewBody">
        {area.title} represents one of the active directions in this research portfolio. This page is designed as a
        dedicated space for future project descriptions, publication lists, methods, and collaborations related to the
        topic.
      </p>
      <p>{area.description}</p>
    </section>

    <section class="info-card">
      <h2 data-i18n="page.researchTopic.currentFocus">Current focus</h2>
      <ul class="feature-list feature-list-light">
        {area.highlights.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
      {area.slug === 'hymeko' && (
        <p>
          <a class="text-link" href="/dissertation">Open related dissertation overview</a>
          {' '}or{' '}
          <a class="text-link" href={dissertation.pdfHref} target="_blank" rel="noreferrer">read the dissertation PDF</a>
        </p>
      )}
      <a class="text-link" href="/research" data-i18n="page.researchTopic.back">Back to all research themes</a>
    </section>
  </section>

  {detail && (
    <>
      <section class="section-block">
        <div class="section-surface">
          <div class="section-heading">
            <p class="section-label">System overview</p>
            <h2>{area.title} as a research framework</h2>
          </div>
          <div class="copy-grid">
            {detail.overview.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </div>
      </section>

      <section class="card-grid-wide">
        <section class="info-card">
          <h2>Core pipeline</h2>
          <ul class="feature-list feature-list-light">
            {detail.pipeline.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>

        <section class="info-card">
          <h2>Dissertation connection</h2>
          <p>{detail.dissertationNote}</p>
          <p>
            <a class="text-link" href="/dissertation">Open dissertation overview</a>
          </p>
          <p>
            <a class="text-link" href={dissertation.pdfHref} target="_blank" rel="noreferrer">Open dissertation PDF</a>
          </p>
          {'repositories' in detail && detail.repositories && (
            <>
              <h3 class="section-subtitle">Framework repositories</h3>
              <div class="chip-row">
                {detail.repositories.map((repository) => (
                  <a class="chip chip-link chip-blue" href={repository.href} target="_blank" rel="noreferrer">
                    {repository.label}
                  </a>
                ))}
              </div>
            </>
          )}
        </section>
      </section>

      <section class="section-block">
        <div class="section-heading section-heading-on-dark">
          <p class="section-label">Capabilities</p>
          <h2>What the framework is designed to support</h2>
        </div>
        <div class="card-grid">
          {detail.capabilities.map((capability) => (
            <article class="info-card">
              <h3>{capability.title}</h3>
              <p>{capability.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="card-grid-wide">
        <section class="info-card">
          <h2>Application domains</h2>
          <ul class="feature-list feature-list-light">
            {detail.domains.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>

        <section class="info-card">
          <h2>Current steps</h2>
          <div class="stack-list compact">
            {detail.currentSteps.map((item) => (
              <article class="stack-item">
                <span>{item}</span>
              </article>
            ))}
          </div>
        </section>
      </section>

      <section class="section-block">
        <div class="section-heading section-heading-on-dark">
          <p class="section-label">Future steps</p>
          <h2>Next directions for {area.title}</h2>
        </div>
        <div class="card-grid">
          {detail.futureSteps.map((item) => (
            <article class="info-card">
              <p>{item}</p>
            </article>
          ))}
        </div>
      </section>

      {area.slug === 'hymeko' && (
        <section class="section-block">
          <div class="section-heading section-heading-on-dark">
            <p class="section-label">Publications</p>
            <h2>HyMeKo-related publications and citation entries</h2>
          </div>
          <div class="stack-list">
            {hymekoBibtexEntries.map((entry) => (
              <article class="info-card">
                <div class="copy-grid">
                  <div>
                    <h3>{entry.title}</h3>
                    <p>
                      {entry.authors.join(', ')}
                      {entry.year ? ` (${entry.year})` : ''}
                    </p>
                    {entry.venue && <p>{entry.venue}</p>}
                  </div>
                  <CopyBlock title={`BibTeX: ${entry.key}`} code={entry.code} language="bibtex" />
                </div>
              </article>
            ))}
          </div>
          <p>
            <a class="text-link" href="/research/hymeko.bib" target="_blank" rel="noreferrer">Open downloadable BibTeX file</a>
          </p>
        </section>
      )}
    </>
  )}
</BaseLayout>
