---
import PageIntro from '../../components/PageIntro.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageSectionNav from '../../components/PageSectionNav.astro';
import { backgroundResearch, focusResearch, researchAreas } from '../../data/profile';
---

<BaseLayout title="Research | Kyberszittya">
  <PageIntro
    kicker="Research"
    title="Themes, models, and applications"
    summary="Research directions spanning semantic modeling, cognitive systems, robotic interaction, and industrial intelligence."
    kickerKey="page.research.kicker"
    titleKey="page.research.title"
    summaryKey="page.research.summary"
    inlineKicker={true}
    stats={[
      { value: `${researchAreas.length}`, label: 'research areas' },
      { value: `${focusResearch.length}`, label: 'focus threads' },
      { value: `${backgroundResearch.length}`, label: 'background threads' },
    ]}
  />

  <section class="page-multi-layout">
    <PageSectionNav
      title="Research sections"
      ariaLabel="Research section navigation"
      entries={[
        { href: '#research-focus', label: 'Research focus' },
        { href: '#research-background', label: 'Research background' },
        { href: '#research-areas', label: 'Research areas' },
      ]}
    />

    <div class="page-multi-content">
  <section class="dual-panel-grid">
    <section class="glass-panel glass-panel-dark" id="research-focus">
      <p class="section-label" data-i18n="research.focus.kicker">Research focus</p>
      <h2 data-i18n="research.focus.title">Focused research challenges</h2>
      <ul class="feature-list">
        {focusResearch.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section class="glass-panel glass-panel-dark" id="research-background">
      <p class="section-label" data-i18n="research.background.kicker">Research background</p>
      <h2 data-i18n="research.background.title">Background research challenges</h2>
      <ul class="feature-list">
        {backgroundResearch.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>
  </section>

  <section class="card-grid" id="research-areas">
    {researchAreas.map((area) => (
      <article class="info-card">
        <h2>{area.title}</h2>
        <p>{area.description}</p>
        <ul class="feature-list feature-list-light">
          {area.highlights.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
        <a class="text-link" href={`/research/${area.slug}`} data-i18n="common.openTopicPage">Open topic page</a>
      </article>
    ))}
  </section>
    </div>
  </section>
</BaseLayout>
