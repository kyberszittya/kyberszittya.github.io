---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageSectionNav from '../../components/PageSectionNav.astro';
import { education } from '../../data/profile';

const subjectsCollection = (await getCollection('subjects')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

const subjects = Array.from(
  subjectsCollection
    .reduce((map, subjectEntry) => {
      const current = map.get(subjectEntry.data.subject);
      const tags = subjectEntry.data.tags ?? [];
      const semesters = subjectEntry.data.semesters ?? [];
      const teachingLanguages = subjectEntry.data.teachingLanguages ?? education.teachingProfile.languages;

      if (!current) {
        map.set(subjectEntry.data.subject, {
          id: subjectEntry.id,
          title: subjectEntry.data.subject,
          heading: subjectEntry.data.title,
          publishDate: subjectEntry.data.publishDate,
          description:
            subjectEntry.data.subjectSummary ??
            `Subject materials and teaching notes for ${subjectEntry.data.subject}.`,
          hostUniversities: [subjectEntry.data.hostUniversity],
          hostDepartments: [subjectEntry.data.hostDepartment],
          degreePrograms: [subjectEntry.data.degreeProgram],
          semesters,
          teachingLanguages,
          tags,
          neptunCode: subjectEntry.data.neptunCode,
          mascot: subjectEntry.data.mascot,
        });
        return map;
      }

      map.set(subjectEntry.data.subject, {
        ...current,
        publishDate:
          subjectEntry.data.publishDate.getTime() > current.publishDate.getTime()
            ? subjectEntry.data.publishDate
            : current.publishDate,
        description: subjectEntry.data.subjectSummary ?? current.description,
        hostUniversities: Array.from(new Set([...current.hostUniversities, subjectEntry.data.hostUniversity])),
        hostDepartments: Array.from(new Set([...current.hostDepartments, subjectEntry.data.hostDepartment])),
        degreePrograms: Array.from(new Set([...current.degreePrograms, subjectEntry.data.degreeProgram])),
        semesters: Array.from(new Set([...current.semesters, ...semesters])),
        teachingLanguages: Array.from(new Set([...current.teachingLanguages, ...teachingLanguages])),
        tags: Array.from(new Set([...current.tags, ...tags])).sort((a, b) => a.localeCompare(b)),
        neptunCode: current.neptunCode ?? subjectEntry.data.neptunCode,
        mascot: current.mascot ?? subjectEntry.data.mascot,
      });

      return map;
    }, new Map<string, {
      id: string;
      title: string;
      heading: string;
      publishDate: Date;
      description: string;
      hostUniversities: string[];
      hostDepartments: string[];
      degreePrograms: string[];
      semesters: string[];
      teachingLanguages: string[];
      tags: string[];
      neptunCode?: string;
      mascot?: {
        name: string;
        shortLabel?: string;
        description?: string;
        accent?: string;
        emoji?: string;
      };
    }>())
    .values(),
).sort((a, b) => a.title.localeCompare(b.title));

const availableTags = Array.from(
  new Set(subjects.flatMap((subject) => subject.tags)),
).sort((a, b) => a.localeCompare(b));

const tagGroupDefinitions = [
  {
    label: 'AI and intelligence',
    tone: 'cyan',
    tags: [
      'Artificial Intelligence',
      'Machine Learning',
      'Deep Learning',
      'Fuzzy Logic',
      'Genetic algorithms',
      'Neural Networks',
      'Natural Language Processing',
      'Computer Vision',
      'Autonomous Systems',
      'Autonomous systems',
    ],
  },
  {
    label: 'Software engineering',
    tone: 'violet',
    tags: [
      'Software development',
      'Version control',
      'Testing frameworks',
      'Monitoring tools',
      'CI/CD',
      'Virtualization',
      'Containerization',
    ],
  },
  {
    label: 'Systems and robotics',
    tone: 'indigo',
    tags: [
      'Robotics',
      'ROS',
      'Systems engineering',
      'SysML',
      'Model-based design',
      'Simulation',
      'Testing and validation',
    ],
  },
  {
    label: 'Industrial and distributed',
    tone: 'magenta',
    tags: [
      'Industry 4.0',
      'Cyber-physical systems',
      'Cloud computing',
      'IoT',
      'Distributed systems',
      'Edge computing',
      'Network protocols',
      'MQTT',
      'OPC-UA',
    ],
  },
] as const;

const groupedAvailableTags = (() => {
  const tagSet = new Set(availableTags);
  const used = new Set<string>();
  const groups = tagGroupDefinitions
    .map((group) => {
      const tags = group.tags.filter((tag) => tagSet.has(tag));
      tags.forEach((tag) => used.add(tag));
      return { ...group, tags };
    })
    .filter((group) => group.tags.length > 0);

  const otherTags = availableTags.filter((tag) => !used.has(tag));
  if (otherTags.length > 0) {
    groups.push({
      label: 'Other topics',
      tone: 'blue',
      tags: otherTags,
    });
  }

  return groups;
})();

const subjectNavItems = subjects.map((subject) => ({
  id: `subject-${subject.id}`,
  label: subject.title,
}));
---

<BaseLayout title="Subjects | Kyberszittya">
  <section class="section-block">
    <div class="section-heading">
      <p class="section-label" data-i18n="page.lectures.kicker">Education</p>
      <h1 class="hero-title" style="font-size: clamp(2.4rem, 5vw, 3.8rem); color: #f8fbff;" data-i18n="page.lectures.title">Subjects</h1>
      <p class="hero-summary" data-i18n="page.lectures.summary">Teaching materials connected to full university subjects taught since 2022, currently offered in English and Hungarian.</p>
      <div class="chip-row" style="margin-top: 1rem;">
        <span class="chip chip-blue">{education.teachingProfile.period}</span>
        {education.teachingProfile.languages.map((language) => (
          <span class="chip">{language}</span>
        ))}
        {subjects.map((subject) => (
          <span class="chip">{subject.title}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="subject-layout">
    <PageSectionNav
      title="Subjects"
      ariaLabel="Subject navigation"
      entries={subjectNavItems.map((item) => ({ href: `#${item.id}`, label: item.label }))}
      className="page-section-nav-subjects"
    />

    <aside class="info-card student-filter-panel subject-filter-sidebar">
      <div class="student-filter-header">
        <div>
          <p class="section-eyebrow">Filter</p>
          <h2 class="section-title">Filter by tags</h2>
          <p class="subject-filter-summary">Toggle whole groups or individual tags without pushing the subject information too far down.</p>
          <div class="student-filter-divider" aria-hidden="true"></div>
        </div>
        <button type="button" class="chip-link student-filter-reset" data-subject-filter-reset>
          Reset
        </button>
      </div>
      <div class="subject-filter-groups" data-subject-filter-controls>
        {groupedAvailableTags.map((group) => (
          <section class="subject-filter-group" data-filter-tone={group.tone} data-subject-filter-group>
            <div class="subject-filter-group-header">
              <p class="subject-filter-group-title">{group.label}</p>
              <button
                type="button"
                class="subject-filter-group-toggle"
                data-subject-group-toggle
              >
                Clear group
              </button>
            </div>
            <div class="student-filter-list subject-filter-list-compact">
              {group.tags.map((tag) => (
                <label class="student-filter-chip">
                  <input type="checkbox" value={tag} checked data-subject-filter-checkbox />
                  <span>{tag}</span>
                </label>
              ))}
            </div>
          </section>
        ))}
      </div>
    </aside>

    <div class="card-grid subject-card-grid">
      {subjects.map((subject) => (
        <article
          class="info-card"
          id={`subject-${subject.id}`}
          data-subject-card
          data-subject-tags={subject.tags.join('|')}
        >
        <p class="section-label">
          <a class="text-link lecture-card-link" href={`/subjects/${subject.id}`}>{subject.title}</a>
        </p>
        <div class="subject-card-header">
          <h2 style="font-size: 1.5rem;">
            <a class="title-link lecture-card-title-link" href={`/subjects/${subject.id}`}>{subject.heading}</a>
          </h2>
          <p>{subject.publishDate.toDateString()}</p>
          <p>{subject.description}</p>
          <div class="subject-card-divider" aria-hidden="true"></div>
        </div>
        {(subject.neptunCode || subject.mascot) && (
          <div class="chip-row">
            {subject.neptunCode && <span class="chip chip-blue">Neptun: {subject.neptunCode}</span>}
            {subject.mascot && (
                <span class="chip">
                  {subject.mascot.emoji ? `${subject.mascot.emoji} ` : ''}{subject.mascot.shortLabel ?? subject.mascot.name}
                </span>
              )}
            </div>
          )}
          <div class="subject-info-group">
            <p class="subject-info-label">Subject information</p>
            <div class="chip-row">
              {subject.hostUniversities.map((hostUniversity) => (
                <span class="chip">{hostUniversity}</span>
              ))}
              {subject.hostDepartments.map((hostDepartment) => (
                <span class="chip">{hostDepartment}</span>
              ))}
            </div>
          </div>
          <div class="subject-info-group">
            <p class="subject-info-label">Degree program</p>
            <div class="chip-row">
              {subject.degreePrograms.map((degreeProgram) => (
                <span class="chip chip-blue">{degreeProgram}</span>
              ))}
            </div>
          </div>
          {subject.semesters.length > 0 && (
            <div class="subject-info-group">
              <p class="subject-info-label">Semesters</p>
              <div class="chip-row">
                {subject.semesters.map((semester) => (
                  <span class="chip">{semester}</span>
                ))}
              </div>
            </div>
          )}
          {subject.teachingLanguages.length > 0 && (
            <div class="subject-info-group">
              <p class="subject-info-label">Teaching languages</p>
              <div class="chip-row">
                {subject.teachingLanguages.map((language) => (
                  <span class="chip">{language}</span>
                ))}
              </div>
            </div>
          )}
          {subject.tags.length > 0 && (
            <div class="subject-info-group">
              <p class="subject-info-label">Tags</p>
              <div class="chip-row">
                {subject.tags.slice(0, 6).map((tag) => (
                  <span class="chip chip-blue">{tag}</span>
                ))}
                {subject.tags.length > 6 && <span class="chip">+{subject.tags.length - 6} more</span>}
              </div>
            </div>
          )}
          <a class="text-link" href={`/subjects/${subject.id}`} data-i18n="page.lectures.read">Open subject</a>
        </article>
      ))}
    </div>
  </section>

  <script is:inline>
    const tagCheckboxes = Array.from(document.querySelectorAll('[data-subject-filter-checkbox]'));
    const subjectCards = Array.from(document.querySelectorAll('[data-subject-card]'));
    const subjectResetButton = document.querySelector('[data-subject-filter-reset]');
    const subjectFilterGroups = Array.from(document.querySelectorAll('[data-subject-filter-group]'));

    const applySubjectTagFilter = () => {
      const activeTags = new Set(
        tagCheckboxes
          .filter((checkbox) => checkbox instanceof HTMLInputElement && checkbox.checked)
          .map((checkbox) => checkbox instanceof HTMLInputElement ? checkbox.value : ''),
      );

      subjectCards.forEach((card) => {
        if (!(card instanceof HTMLElement)) return;
        const cardTags = new Set((card.dataset.subjectTags ?? '').split('|').filter(Boolean));
        card.hidden = activeTags.size > 0 && !Array.from(cardTags).some((tag) => activeTags.has(tag));
      });

      subjectFilterGroups.forEach((group) => {
        if (!(group instanceof HTMLElement)) return;
        const groupCheckboxes = Array.from(group.querySelectorAll('[data-subject-filter-checkbox]'))
          .filter((checkbox) => checkbox instanceof HTMLInputElement);
        const toggle = group.querySelector('[data-subject-group-toggle]');
        if (!(toggle instanceof HTMLButtonElement)) return;

        const allChecked = groupCheckboxes.length > 0 && groupCheckboxes.every((checkbox) => checkbox.checked);
        const anyChecked = groupCheckboxes.some((checkbox) => checkbox.checked);

        toggle.textContent = allChecked ? 'Clear group' : 'Select group';
        toggle.dataset.state = allChecked ? 'all' : anyChecked ? 'partial' : 'none';
      });
    };

    tagCheckboxes.forEach((checkbox) => {
      checkbox.addEventListener('change', applySubjectTagFilter);
    });

    subjectFilterGroups.forEach((group) => {
      if (!(group instanceof HTMLElement)) return;
      const toggle = group.querySelector('[data-subject-group-toggle]');
      if (!(toggle instanceof HTMLButtonElement)) return;

      toggle.addEventListener('click', () => {
        const groupCheckboxes = Array.from(group.querySelectorAll('[data-subject-filter-checkbox]'))
          .filter((checkbox) => checkbox instanceof HTMLInputElement);
        const shouldCheck = !groupCheckboxes.every((checkbox) => checkbox.checked);

        groupCheckboxes.forEach((checkbox) => {
          checkbox.checked = shouldCheck;
        });

        applySubjectTagFilter();
      });
    });

    subjectResetButton?.addEventListener('click', () => {
      tagCheckboxes.forEach((checkbox) => {
        if (checkbox instanceof HTMLInputElement) {
          checkbox.checked = true;
        }
      });
      applySubjectTagFilter();
    });

    applySubjectTagFilter();
  </script>
</BaseLayout>
